{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.artic.edu/schemas/product.schema.json",
  "title": "Product",
  "type": "object",
  "description": "Museum shop product.",
  "properties": {
    "id": {
      "type": "integer"
    },
    "api_model": {
      "type": "string"
    },
    "api_link": {
      "type": "string",
      "format": "uri"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "external_sku": {
      "type": [
        "string",
        "null"
      ]
    },
    "image_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "web_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "min_current_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "max_current_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "min_compare_at_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "max_compare_at_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "price_display": {
      "type": [
        "string",
        "null"
      ]
    },
    "artist_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "artwork_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "exhibition_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "source_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "title",
    "api_model",
    "api_link"
  ]
}